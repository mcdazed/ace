{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Validate Config",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/tools"
            },
            "args": [
                "config_style_checker.py"
            ]
        },
        {
            "label": "Validate Stringtables",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/tools"
            },
            "args": [
                "stringtable_validator.py"
            ]
        },
        {
            "label": "Check Strings",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/tools"
            },
            "args": [
                "check_strings.py"
            ]
        },
        {
            "label": "SQFVM Checker",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/tools"
            },
            "args": [
                "sqfvmChecker.py"
            ],
            "problemMatcher": []
        },
        {
            "label": "Validate headers",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/docs/tools"
            },
            "args": [
                "document_functions.py",
                "--debug"
            ]
        },
        {
            "label": "HEMTT check",
            "command": "hemtt.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "check"
            ],
            "problemMatcher": []
        },
        {
            "label": "Test All",
            "dependsOn": [
                "Validate SQF",
                "Validate Config",
                "Validate Stringtables",
                "Validate headers",
                "Check Strings",
                "HEMTT check"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Build: make.py (pboProject)",
            "command": "C:\\Python313\\python.exe",
            "options": {
                "cwd": "${workspaceFolder}/tools"
            },
            "args": [
                "make.py",
                "ci"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Build: HEMTT",
            "command": "hemtt.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "build",
                "-v"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Dev: HEMTT",
            "command": "hemtt.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "dev",
                "-v"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build: HEMTT --just",
            "command": "python",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "tools/build_current_addon.py",
                "${relativeFile}"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Extension: make move_x64_release",
            "command": "cargo",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "make",
                "move_x64_release"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Extension: make release",
            "command": "cargo",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "make",
                "release"
            ],
            "group": {
                "kind": "build"
            }
        }
    ],
    "inputs": [
        {
            "id": "addon",
            "description": "Addon Name:",
            "default": "common",
            "type": "promptString"
        }
    ]
}
